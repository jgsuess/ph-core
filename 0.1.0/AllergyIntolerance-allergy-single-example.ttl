# - resource -------------------------------------------------------------------

<https://fhir.doh.gov.ph/phcore/AllergyIntolerance/allergy-single-example> a fhir:AllergyIntolerance ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "allergy-single-example"] ; # 
