  ] ; # 
  fhir:onset [
     a fhir:dateTime ;
     fhir:v "2020-03-15"^^xsd:date
  ] ; # 
  fhir:recordedDate [ fhir:v "2020-03-15T10:30:00Z"^^xsd:dateTime] ; # 
  fhir:note ( [
     fhir:text [ fhir:v "Patient advised on diet and exercise management." ]
  ] ) . # 

