     fhir:reference [ fhir:v "Organization/organization-single-example" ]
  ] ; # 
  fhir:code ( [
     fhir:coding ( [
       fhir:system [ fhir:v "http://terminology.hl7.org/CodeSystem/practitioner-role"^^xsd:anyURI ] ;
       fhir:code [ fhir:v "doctor" ] ;
       fhir:display [ fhir:v "Doctor" ]
     ] )
  ] ) ; # 
  fhir:specialty ( [
